# Redis — must be the same instance jobpilot-backend uses for BullMQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# MongoDB Atlas — same DB as jobpilot-backend (apply_jobs status)
MONGODB_URI=

# Queue name (must match API APPLY_QUEUE_NAME)
APPLY_QUEUE_NAME=apply

# noop     = ack only (testing)
# open     = Playwright opens applyUrl
# greenhouse = fill Greenhouse form + upload resume
APPLY_MODE=greenhouse

# false = fill form only (status: opened). true = click Submit (status: applied)
APPLY_SUBMIT=false

# API for resume download (same secret as backend APPLY_WORKER_SECRET)
API_PUBLIC_URL=https://jobpilot-api.duckdns.org
APPLY_WORKER_SECRET=change-me-same-as-backend

# Optional — many Greenhouse forms require phone
APPLY_DEFAULT_PHONE=

PLAYWRIGHT_HEADLESS=true
CONCURRENCY=1
NAVIGATION_TIMEOUT_MS=60000

# Health check: GET /health
HEALTH_HOST=0.0.0.0
HEALTH_PORT=3100

# Greenhouse email security code timeout (Telegram is linked per user in JobPilot UI; bot token lives on backend)
TELEGRAM_CODE_TIMEOUT_MS=600000
