# Redis — must be the same instance jobpilot-backend uses for BullMQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# MongoDB Atlas (optional in Phase 1; required once API writes apply_jobs)
MONGODB_URI=

# Queue name (must match API APPLY_QUEUE_NAME)
APPLY_QUEUE_NAME=apply

# noop = acknowledge jobs without browser (safe default for Phase 1)
# open  = Playwright navigates to applyUrl (Phase A)
APPLY_MODE=noop

PLAYWRIGHT_HEADLESS=true
CONCURRENCY=1
NAVIGATION_TIMEOUT_MS=60000
